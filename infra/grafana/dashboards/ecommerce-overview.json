        { "expr": "sum(rate(http_requests_total{job=\"ecommerce-api\",status_code=~\"4..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"ecommerce-api\"}[5m])), 0.001)", "legendFormat": "4xx ratio", "refId": "B" }
